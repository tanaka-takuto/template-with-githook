#!/bin/sh

set -eu

protected_branches='^(main|develop)$'
issue_branch_pattern='^issue/#[0-9]+$'

status=0

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/*)
      branch=${remote_ref#refs/heads/}
      ;;
    *)
      continue
      ;;
  esac

  case "$local_sha" in
    0000000000000000000000000000000000000000)
      continue
      ;;
  esac

  if printf '%s\n' "$branch" | grep -Eq "$protected_branches"; then
    continue
  fi

  if printf '%s\n' "$branch" | grep -Eq "$issue_branch_pattern"; then
    continue
  fi

  cat >&2 <<EOF
pre-push: remote branch "$branch" is not allowed.

Allowed branch names:
  main
  develop
  issue/#123

Create an issue branch with:
  git switch -c 'issue/#123'
EOF
  status=1
done

exit "$status"
